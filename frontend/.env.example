# ─── Royal Beauty Salon — Frontend Environment Variables ───
# Copy to .env.local for local dev. In production (Vercel), set the same
# names in Project → Settings → Environment Variables.

# ════════════════════════════════════════════════════════════════════════
# REQUIRED
# ════════════════════════════════════════════════════════════════════════

# The backend's public URL (Render). Service pages are fetched from here
# at build time and /api/* requests are proxied here at runtime — see
# next.config.ts's rewrites(). The build FAILS LOUD if this is unset or
# unreachable, by design: a silently degraded catalog would deindex 75+
# live SEO pages.
BACKEND_URL="https://royal-beauty-backend.onrender.com"

NEXTAUTH_URL="https://www.royalbeautysaloon.com"
# MUST exactly match the backend's NEXTAUTH_SECRET.
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Gates POST /revalidate, called by the backend after every services/
# testimonials/gallery mutation so ISR doesn't wait out its cache window.
# MUST exactly match the backend's REVALIDATE_SECRET.
REVALIDATE_SECRET="generate-with: openssl rand -base64 32"

# Drives every canonical tag, the sitemap, and Open Graph. MUST be the
# exact domain the host serves (including www).
NEXT_PUBLIC_SITE_URL="https://www.royalbeautysaloon.com"

# ════════════════════════════════════════════════════════════════════════
# RECOMMENDED
# ════════════════════════════════════════════════════════════════════════

NEXT_PUBLIC_SALON_PHONE="+48 22 123 45 67"
NEXT_PUBLIC_SALON_WHATSAPP="48221234567"
NEXT_PUBLIC_SALON_EMAIL="warsawroyalbeauty@gmail.com"

# ════════════════════════════════════════════════════════════════════════
# OPTIONAL
# ════════════════════════════════════════════════════════════════════════

# Only needed if the admin Gallery UI renders Cloudinary delivery URLs.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"

# EmailJS — a client-side-only backup notification path for the public
# Contact form. Safe to leave blank.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=""
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=""
NEXT_PUBLIC_EMAILJS_CONTACT_TEMPLATE_ID=""
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=""

NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""
