# ─── Royal Beauty Salon — Environment Variables ───
# Copy this file to .env.local for local dev. For production, set the same
# names in your host's dashboard (e.g. Vercel → Project → Settings →
# Environment Variables) — .env files are never deployed, only used locally.

# ════════════════════════════════════════════════════════════════════════
# REQUIRED — the site runs in a degraded "demo mode" without these
# ════════════════════════════════════════════════════════════════════════

# MongoDB connection string. MUST be a hosted database (e.g. MongoDB Atlas)
# in production — a "mongodb://localhost:27017" value only works on the
# machine actually running MongoDB and will silently no-op on Vercel.
MONGODB_URI="mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/royal-beauty?retryWrites=true&w=majority"

# NextAuth — required for /admin login to work at all.
# NEXTAUTH_URL must exactly match the live URL (including https:// and www).
# NEXTAUTH_SECRET is a random string — generate with: openssl rand -base64 32
NEXTAUTH_URL="https://www.royalbeautysaloon.com"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Seed admin credentials — used once by `npm run seed` to create the real
# admin user in MongoDB, and as a fallback login if MONGODB_URI is unset.
ADMIN_EMAIL="admin@royalbeautysalon.pl"
ADMIN_PASSWORD="change-this-strong-password"

# Public site URL — drives every canonical tag, the sitemap, and Open Graph.
# MUST be the exact domain the host serves (including www — the apex
# royalbeautysaloon.com 308-redirects to www.royalbeautysaloon.com, so a
# non-www value here makes every canonical a redirect and blocks indexing).
NEXT_PUBLIC_SITE_URL="https://www.royalbeautysaloon.com"

# ════════════════════════════════════════════════════════════════════════
# STRONGLY RECOMMENDED
# ════════════════════════════════════════════════════════════════════════

# Resend API key — powers booking confirmation emails and contact-form
# notifications (src/lib/email.ts). Free tier: 100 emails/day at resend.com.
# Without it, bookings and contact messages still save to the database —
# they just don't trigger an email.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxx"
SMTP_FROM="Royal Beauty Salon <no-reply@royalbeautysalon.pl>"

# Where new-booking / contact-form admin notifications are delivered.
# Falls back to ADMIN_EMAIL, then a hardcoded default, if unset.
ADMIN_NOTIFICATION_EMAIL="warsawroyalbeauty@gmail.com"

# Salon contact details rendered across the site UI.
NEXT_PUBLIC_SALON_PHONE="+48 22 123 45 67"
NEXT_PUBLIC_SALON_WHATSAPP="48221234567"
NEXT_PUBLIC_SALON_EMAIL="warsawroyalbeauty@gmail.com"

# ════════════════════════════════════════════════════════════════════════
# OPTIONAL
# ════════════════════════════════════════════════════════════════════════

# Cloudinary — only needed for the admin Gallery image-upload feature.
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"

# EmailJS — an alternative, client-side-only notification path used solely
# by the public Contact form (src/components/sections/Contact.tsx) as a
# backup to RESEND_API_KEY. Not used by the booking flow. Safe to leave blank.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=""
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=""
NEXT_PUBLIC_EMAILJS_CONTACT_TEMPLATE_ID=""
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=""

# Google Search Console "HTML tag" verification (the content="..." value
# only). Optional if the property is verified via DNS or HTML file upload.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""
