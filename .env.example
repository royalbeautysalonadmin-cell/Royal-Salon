# ─── Royal Beauty Salon — Environment Variables ───

# MongoDB Atlas connection string
MONGODB_URI="mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/royal-beauty?retryWrites=true&w=majority"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Seed admin credentials (used by `npm run seed`)
ADMIN_EMAIL="admin@royalbeautysalon.pl"
ADMIN_PASSWORD="change-this-strong-password"

# Nodemailer (SMTP) — e.g. Gmail App Password, Resend SMTP, Mailtrap
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="Royal Beauty Salon <no-reply@royalbeautysalon.pl>"

# Resend API (recommended — free 100 emails/day at resend.com)
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxx"

# EmailJS (easiest setup — client-side, no SMTP needed)
# 1. Sign up at https://www.emailjs.com
# 2. Connect your Gmail (one-click)
# 3. Create 2 email templates (booking + contact)
# 4. Fill in your Service ID, Template IDs, and Public Key below
NEXT_PUBLIC_EMAILJS_SERVICE_ID=""
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=""
NEXT_PUBLIC_EMAILJS_CONTACT_TEMPLATE_ID=""
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=""

# Where new-booking admin notifications are delivered
ADMIN_NOTIFICATION_EMAIL="warsawroyalbeauty@gmail.com"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"

# Public site URL (used for SEO / canonical / sitemap / Open Graph)
# IMPORTANT: in production this MUST be the exact domain the host serves —
# including the www prefix. The apex royalbeautysaloon.com 308-redirects to
# www.royalbeautysaloon.com, so a non-www value makes every canonical and
# sitemap URL a redirect and Google will not index the pages.
NEXT_PUBLIC_SITE_URL="https://www.royalbeautysaloon.com"

# Google Search Console "HTML tag" verification (the content="..." value only).
# Optional if the property is verified via DNS or HTML file upload.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# Salon contact details (rendered in UI)
NEXT_PUBLIC_SALON_PHONE="+48 22 123 45 67"
NEXT_PUBLIC_SALON_WHATSAPP="48221234567"
NEXT_PUBLIC_SALON_EMAIL="warsawroyalbeauty@gmail.com"
