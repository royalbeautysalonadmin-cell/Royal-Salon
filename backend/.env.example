# ─── Royal Beauty Salon — Backend Environment Variables ───
# Copy to .env.local for local dev. In production (Render), set the same
# names in the dashboard — .env files are never deployed, only used locally.

# ════════════════════════════════════════════════════════════════════════
# REQUIRED
# ════════════════════════════════════════════════════════════════════════

MONGODB_URI="mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/royal-beauty?retryWrites=true&w=majority"

# Must be the PUBLIC site domain (e.g. https://www.royalbeautysaloon.com),
# NOT this service's own Render URL — sessions are verified against cookies
# issued for the public domain via the frontend's /api/auth/* rewrite.
NEXTAUTH_URL="https://www.royalbeautysaloon.com"
# MUST exactly match the frontend's NEXTAUTH_SECRET — generate once with:
# openssl rand -base64 32
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Seed admin credentials — used once by `npm run seed` to create the real
# admin user in MongoDB, and as a fallback login if MONGODB_URI is unset.
ADMIN_EMAIL="admin@royalbeautysalon.pl"
ADMIN_PASSWORD="change-this-strong-password"

# ════════════════════════════════════════════════════════════════════════
# STRONGLY RECOMMENDED
# ════════════════════════════════════════════════════════════════════════

RESEND_API_KEY="re_xxxxxxxxxxxxxxxx"
SMTP_FROM="Royal Beauty Salon <no-reply@royalbeautysalon.pl>"
ADMIN_NOTIFICATION_EMAIL="warsawroyalbeauty@gmail.com"

# ════════════════════════════════════════════════════════════════════════
# OPTIONAL
# ════════════════════════════════════════════════════════════════════════

# Cloudinary — only needed for the admin Gallery image-upload feature.
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Salon contact details used in transactional emails.
NEXT_PUBLIC_SALON_PHONE="+48 22 123 45 67"
NEXT_PUBLIC_SALON_EMAIL="warsawroyalbeauty@gmail.com"

# Render assigns this automatically — do not set manually in production.
PORT=4000
